{
  "name": "Chrome KasmVNC",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "forwardPorts": [6901],
  "portsAttributes": {
    "6901": {
      "label": "Chrome Desktop",
      "onAutoForward": "notify"
    }
  },
  "postStartCommand": "bash /opt/auto-start.sh",
  "remoteUser": "vscode",
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  }
}