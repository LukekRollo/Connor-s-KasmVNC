{
  "name": "Chrome KasmVNC",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "forwardPorts": [6901],
  "portsAttributes": {
    "6901": {
      "label": "Chrome Desktop",
      "onAutoForward": "openBrowser"
    }
  },
  "postStartCommand": "nohup bash /opt/start-vnc.sh > /tmp/vnc-startup.log 2>&1 &",
  "remoteUser": "vscode",
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  }
}